{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "flask_api.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server.js" },
    { "src": "/flask/(.*)", "dest": "/flask_api.py" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
